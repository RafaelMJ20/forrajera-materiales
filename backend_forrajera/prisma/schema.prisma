// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Categoría de productos
model Category {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  description String?
  active    Int       @default(1) // 1 = activo, 0 = eliminado (borrado lógico)
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("categories")
}

// Producto
model Product {
  id              Int       @id @default(autoincrement())
  name            String
  categoryId      Int
  category        Category  @relation(fields: [categoryId], references: [id])
  purchasePrice   Float     // Precio de compra
  salePrice       Float     // Precio de venta
  currentStock    Float     // Stock actual
  minimumStock    Float     // Stock mínimo para alertas
  unit            String    // Unidad de medida (pieza, kilo, litro, costal, etc.)
  photo           String?   // URL o ruta de la foto
  active          Int       @default(1) // 1 = activo, 0 = eliminado (borrado lógico)
  saleItems       SaleItem[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("products")
}

// Venta
model Sale {
  id        Int         @id @default(autoincrement())
  saleDate  DateTime    @default(now())
  notes     String?     // Notas opcionales (nombre del cliente, observaciones)
  total     Float       // Total de la venta
  gain      Float       // Ganancia total (suma de ganancias de cada producto)
  items     SaleItem[]  // Ítems de la venta
  active    Int         @default(1) // 1 = activo, 0 = eliminado (borrado lógico)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@map("sales")
}

// Ítems de venta (detalle de cada producto vendido)
model SaleItem {
  id          Int     @id @default(autoincrement())
  saleId      Int
  sale        Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId   Int
  product     Product @relation(fields: [productId], references: [id])
  quantity    Float   // Cantidad vendida
  unitPrice   Float   // Precio unitario al momento de la venta
  subtotal    Float   // Subtotal del ítem (quantity * unitPrice)
  gain        Float   // Ganancia del ítem (quantity * (salePrice - purchasePrice))

  @@map("sale_items")
}

// Vehículo
model Vehicle {
  id                Int            @id @default(autoincrement())
  brand             String         // Marca (Toyota, Ford, etc.)
  model             String         // Modelo (Hilux, F150, etc.)
  licensePlate      String         @unique // Placas únicas
  year              Int            // Año del vehículo
  type              String         // Tipo (camioneta, camión, auto, etc.)
  expectedFuelEfficiency Float       // Rendimiento esperado (km/litro)
  photo             String?        // URL o ruta de la foto
  active            Int            @default(1) // 1 = activo, 0 = eliminado
  fuelLogs          FuelLog[]      // Registros de combustible
  maintenanceLogs   MaintenanceLog[] // Registros de mantenimiento
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@map("vehicles")
}

// Registro de carga de combustible
model FuelLog {
  id                Int       @id @default(autoincrement())
  vehicleId         Int
  vehicle           Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  fuelDate          DateTime  @default(now())
  litersLoaded      Float     // Litros cargados
  costTotal         Float     // Costo total de la carga
  currentMileage    Float     // Kilometraje al momento de cargar
  gasStation        String?   // Gasolinera donde cargó
  driver            String?   // Chofer responsable (opcional)
  notes             String?   // Notas adicionales
  active            Int       @default(1) // 1 = activo, 0 = eliminado
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@map("fuel_logs")
}

// Registro de mantenimiento
model MaintenanceLog {
  id                Int       @id @default(autoincrement())
  vehicleId         Int
  vehicle           Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  maintenanceDate   DateTime  @default(now())
  serviceType       String    // Tipo de servicio (cambio de aceite, mantenimiento general, etc.)
  mileage           Float?    // Kilometraje al momento del servicio
  cost              Float?    // Costo del servicio
  notes             String?   // Notas detalladas
  nextServiceDate   DateTime? // Próximo servicio recomendado
  active            Int       @default(1) // 1 = activo, 0 = eliminado
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@map("maintenance_logs")
}


